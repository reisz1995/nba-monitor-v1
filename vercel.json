{
    "version": 2,
    "functions": {
        "api/**/*.js": {
            "memory": 1024,
            "maxDuration": 60
        },
        "api/**/*.ts": {
            "memory": 1024,
            "maxDuration": 60
        }
    },
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Access-Control-Allow-Methods",
                    "value": "GET, POST, OPTIONS"
                }
            ]
        }
    ]
}